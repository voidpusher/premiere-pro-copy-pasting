{
  "name": "instant-paste-helper",
  "version": "1.0.0",
  "description": "Instant Paste Electron clipboard helper service",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc -w",
    "build": "tsc",
    "start": "electron dist/main.js",
    "start:dev": "npm run build && electron dist/main.js",
    "package:win": "electron-builder --win --x64",
    "package:mac": "electron-builder --mac"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ws": "^8.14.0",
    "sharp": "^0.32.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0",
    "typescript": "^5.0.0"
  },
  "build": {
    "appId": "com.instantpaste.helper",
    "productName": "InstantPasteHelper",
    "files": ["dist/**/*"],
    "win": {
      "target": "portable",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": "dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
